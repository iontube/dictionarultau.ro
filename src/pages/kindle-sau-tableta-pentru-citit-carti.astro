const slug = "kindle-sau-tableta-pentru-citit-carti";

const faq = [
  { question: "Pot citi orice fel de carte pe un Kindle sau o tableta?", answer: "Pe un Kindle, cel mai usor citesti carti cumparate din magazinul Amazon. Poate citi si alte formate (EPUB, PDF) dar uneori necesita conversie, ceea ce poate fi incomod. Tabletele, fiind dispozitive universale, pot citi practic orice format prin diverse aplicatii." },
