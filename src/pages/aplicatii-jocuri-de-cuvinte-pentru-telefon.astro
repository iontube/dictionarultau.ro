import CookieBanner from '../components/CookieBanner.astro';
import keywordsData from '../../keywords.json';

const title = "Aplicatii jocuri de cuvinte pentru telefon";
const excerpt = "Am descoperit recent o lume fascinantă a jocurilor de cuvinte pe telefon. Sunt un fan înfocat al învățării limbilor străine și mereu caut metode noi și distractive să-mi exersez vocabularul. Aceste aplicații mi-au devenit rapid nelipsite.";
const image = "/images/articles/aplicatii-jocuri-de-cuvinte-pentru-telefon.webp";
const category = "Jocuri de Cuvinte";
const categorySlug = "jocuri-de-cuvinte";
const date = "2026-02-04T14:41:05.969Z";
const modifiedDate = "2026-02-04T14:41:05.969Z";
const author = "Elena Dumitrescu";
const authorRole = "Specialist in Jocuri Educative";
const authorBio = "Elena crede ca invatarea trebuie sa fie distractiva. Te ajuta sa descoperi cele mai captivante jocuri care iti dezvolta vocabularul.";
const slug = "aplicatii-jocuri-de-cuvinte-pentru-telefon";

const faq = [
  { question: "Ce joc de cuvinte e cel mai bun pentru a invata limba engleza?", answer: "Pentru invatarea limbii engleze, jocurile de tip \"crossword\" sau \"Scrabble\" sunt excelente. Acestea te forteaza sa intelegi definitiile si sa folosesti vocabularul in mod strategic. Wordscapes si Word Connect sunt bune pentru familiarizarea cu cuvinte comune si structuri de baza." },
  { question: "Exista jocuri de cuvinte bune si pentru limba romana?", answer: "Da, exista. Cauta aplicatii care specifica \"Romanian\" in descriere. Cele de tip \"crossword\" sau \"word search\" pot fi adaptate. Unele aplicatii internationale pot avea si optiunea de limba romana, dar verifica calitatea dictionarului." },
  { question: "Pot folosi aceste jocuri pentru a-mi imbunatati memoria?", answer: "Absolut. Jocurile de cuvinte stimuleaza activitatea cerebrala, imbunatatesc memoria de lucru, concentrarea si capacitatea de rezolvare a problemelor. Repetitia si recunoasterea modelelor in cuvinte sunt benefice." },
  { question: "Cat de des ar trebui sa joc pentru a vedea rezultate?", answer: "Constant, dar fara presiune. Chiar si 15-20 de minute pe zi, jucate constant, pot face o diferenta. Cheia este regularitatea, nu durata sesiunilor individuale." },
  { question: "Aplicatiile gratuite sunt suficiente sau trebuie sa cumpar?", answer: "Majoritatea aplicatiilor gratuite sunt foarte bune si ofera mult continut. Cumpararea variantelor premium este utila daca vrei sa elimini reclamele sau sa accesezi functii suplimentare. Nu e obligatoriu, dar poate imbunatati experienta." },
  { question: "Ce inseamna \"pay-to-win\" in jocurile de cuvinte?", answer: "In jocurile de cuvinte, \"pay-to-win\" se refera la situatiile in care jucatorii trebuie sa plateasca pentru a obtine avantaje semnificative, cum ar fi indicii nelimitate, vieti suplimentare sau posibilitatea de a sari peste nivele dificile, ceea ce poate strica echilibrul si placerea jocului." }
];

const toc = [
  { title: "De ce merita atentia ta", id: "de-ce-merita-atentia-ta" },
  { title: "Variante pe care le poti alege", id: "variante-pe-care-le-poti-alege" },
  { title: "La ce sa te uiti cand alegi", id: "la-ce-sa-te-uiti-cand-alegi" },
  { title: "Ce functioneaza si ce nu", id: "ce-functioneaza-si-ce-nu" },
  { title: "Trucuri utile", id: "trucuri-utile" },
  { title: "Ce as alege eu", id: "ce-as-alege-eu" }
];

// Get all articles for similar articles component
const allArticles = (keywordsData.completed || []).map(item => ({
  title: item.title,
  slug: item.slug,
  excerpt: item.excerpt || '',
  image: item.image,
  category: item.category,
  categorySlug: item.categorySlug,
  date: item.date || new Date().toISOString()
}));
---

<Layout
