  { title: "Top 4 variante de Boggle joc de cuvinte clasic (si ce sa NU cumperi)", id: "top-4-variante-de-boggle-joc-de-cuvinte-clasic-si-ce-sa-nu-cumperi" },
  { title: "Cum sa alegi Boggle joc de cuvinte clasic pentru tine", id: "cum-sa-alegi-boggle-joc-de-cuvinte-clasic-pentru-tine" },
