const faq = [
  { question: "Sunt jocurile de cuvinte cu adevarat eficiente pentru invatarea unei limbi straine?", answer: "Da, pot fi foarte eficiente mai ales pentru extinderea vocabularului, memorarea cuvintelor noi si imbunatatirea vitezei de gandire in limba respectiva. Nu inlocuiesc insa studiul gramaticii sau practica vorbirii." },
